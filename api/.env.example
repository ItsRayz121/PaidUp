# Copy to .env and fill in as needed. All have safe local defaults.

PORT=4000

# Session signing. CHANGE THIS to a long random string before any real use.
JWT_SECRET=dev-only-change-me
# Extra secret mixed into OTP hashing. CHANGE before real use.
OTP_PEPPER=dev-only-change-me-too

# Where the frontend runs (for CORS)
WEB_ORIGIN=http://localhost:3000

# --- Email ---
# Provider priority: Resend (if RESEND_API_KEY set) > Brevo (if BREVO_API_KEY
# set) > console log (local dev). Leave both empty locally to print codes.
# EMAIL_FROM must be a sender your provider allows:
#   - Resend: a verified domain (e.g. login@yourdomain.com), or onboarding@resend.dev
#     for testing (only sends to your own account email). Gmail is NOT allowed.
#   - Brevo: a verified sender (a single Gmail can be verified).
RESEND_API_KEY=
BREVO_API_KEY=
EMAIL_FROM=login@paidup.app
EMAIL_FROM_NAME=PaidUp
