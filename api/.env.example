# Copy to .env and fill in as needed. All have safe local defaults.

PORT=4000

# Postgres. Leave EMPTY locally: the API then runs PGlite (embedded Postgres)
# under api/data/pg — no install needed, same SQL. Set on Railway to the
# Postgres plugin's connection string. Production refuses to boot without it.
DATABASE_URL=

# Session signing. CHANGE THIS to a long random string before any real use.
JWT_SECRET=dev-only-change-me
# Extra secret mixed into OTP hashing. CHANGE before real use.
OTP_PEPPER=dev-only-change-me-too

# Where the frontend runs (for CORS)
WEB_ORIGIN=http://localhost:3000

# --- Email ---
# Resend if RESEND_API_KEY is set, else codes print to the console (local dev).
# EMAIL_FROM must be on a domain verified in Resend (e.g. login@yourdomain.com),
# or onboarding@resend.dev for testing (only sends to your own account email).
# A Gmail address is NOT allowed as the sender.
RESEND_API_KEY=
EMAIL_FROM=login@paidup.app
EMAIL_FROM_NAME=PaidUp

# --- Ad-network postback secrets ---
# One shared secret per network for verifying inbound S2S postbacks (HMAC).
# Empty locally falls back to a known dev secret so the demo adapters verify.
# Set real per-network secrets in production.
POSTBACK_SECRET_OFFERHUB=
POSTBACK_SECRET_TAPVID=
POSTBACK_SECRET_SURVEYX=
# tapvid also gates with a static shared token in addition to the signature.
POSTBACK_TOKEN_TAPVID=
